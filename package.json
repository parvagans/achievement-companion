{
  "name": "steam-deck-achievement-companion",
  "private": true,
  "version": "0.2.8",
  "author": "Adam <nullbit5@protonmail.com>",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:steamos": "rollup -c rollup.steamos.config.js",
    "start:steamos": "python -m backend.dev_shell",
    "doctor:steamos": "python -m backend.steamos_doctor",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:release": "python scripts/package_release.py",
    "check:release": "python scripts/check_release_artifact.py",
    "package:steamos-preview": "python scripts/package_steamos_preview.py",
    "check:steamos-preview": "python scripts/check_steamos_preview_artifact.py",
    "test": "node --import tsx --test tests/createAppServices.test.ts tests/app-runtime.test.ts tests/app-runtime-nondecky.test.ts tests/steamos-adapters.test.ts tests/steamos-runtime.test.ts tests/steamos-runtime-metadata.test.ts tests/steamos-bootstrap.test.ts tests/steamos-bootstrap-entrypoint.test.tsx tests/steamos-dashboard-surface.test.tsx tests/steamos-setup-surface.test.tsx && python -m unittest discover -s tests/python -p \"test_*.py\""
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "@decky/ui": "4.11.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^5.3.4"
  },
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router": "5.1.20",
    "rollup": "^4.53.3",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
